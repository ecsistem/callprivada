APP_ENV=development
HTTP_PORT=8080

DATABASE_URL=postgres://fwlc:fwlc@postgres:5432/fwlc?sslmode=disable
REDIS_URL=redis:6379

JWT_SECRET=change-me
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_HOURS=168

S3_ENDPOINT=minio:9000
S3_REGION=us-east-1
S3_BUCKET=fwlc
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false

ABACATEPAY_API_KEY=change_me
ABACATEPAY_WEBHOOK_SECRET=change_me
ABACATEPAY_BASE_URL=https://api.abacatepay.com

PUBLIC_BASE_URL=http://localhost:5173

# Storage: "s3" (MinIO/S3) ou "local" (disco da VPS)
STORAGE_DRIVER=s3
# Usado quando STORAGE_DRIVER=local — diretório absoluto no servidor
LOCAL_STORAGE_PATH=/data/uploads
